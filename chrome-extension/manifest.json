{
  "manifest_version": 3,
  "name": "JobOffer Scanner",
  "version": "1.0.0",
  "description": "Analyze the job posting on the current tab with your JobOffer Scanner account.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze this job posting"
  },
  "icons": {}
}
