# Copy to .env and fill in whichever provider you want to use.
# Auto-detection order: Anthropic -> OpenAI -> Featherless.
# Override with LLM_PROVIDER=anthropic|openai|featherless.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=                 # optional; SDK uses default if unset

# OpenAI
# OPENAI_API_KEY=sk-...

# Featherless (OpenAI-compatible, hosts Qwen / DeepSeek)
# FEATHERLESS_API_KEY=...

# Tuning (optional)
# LLM_PROVIDER=anthropic
# LLM_TEMPERATURE=0.4
# LLM_MAX_TOKENS=2000
# LLM_MAX_RETRIES=3

# Persistence
# DATABASE_URL=postgresql://user:pass@localhost:5432/joboffer
# Default (unset): SQLite at ./data/joboffer.db (created automatically).

# Phase 1 data sources (optional, degrade honestly if unset)
# NEWS_API_KEY=...                    # newsapi.org for real company news
# LAYOFFS_DATASET_URL=...              # JSON dataset URL with layoff records

# Agentic web-search fallback (keyless): when NEWS_API_KEY is absent but an
# LLM provider key IS set, the company-news fetch falls back to an LLM-directed
# DuckDuckGo search ([research] extra: ddgs) + synthesis. Disable with:
# COMPANY_RESEARCH_FALLBACK=0
# DDG_MAX_RESULTS=5
# Optional hosted headless agentic browser for deep-fetching a top result:
# BROWSERBASE_API_KEY=...
# BROWSERBASE_PROJECT_ID=...           # both required; falls back to local
#                                      # Playwright when BROWSER_SCRAPER_ENABLED=1

# Phase 4 — real salary benchmarks via Adzuna (free tier, ~1000 calls/month)
# Sign up at https://developer.adzuna.com/
# ADZUNA_APP_ID=...
# ADZUNA_APP_KEY=...

# Phase 5 — real cost-of-living data (JSON dataset, e.g. self-hosted Numbeo
# scrape or any city-keyed index). Each record needs a "city" field; supported
# numeric fields: cost_of_living_index, rent_index, groceries_index,
# local_purchasing_power, monthly_rent_1bedroom_city_center, etc.
# COL_DATASET_URL=...

# Migrations: set to 1 to opt into Alembic-managed schema. When unset, init_db
# uses create_all (zero-config). With USE_ALEMBIC=1 run `alembic upgrade head`
# at deploy time.
# USE_ALEMBIC=1

# Async job queue (optional — needs the [worker] extra: celery + redis).
# When unset, analysis runs in-process. docker-compose sets this automatically.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Webhook delivery durability — with a Celery broker, deliveries run as a
# retrying task (at-least-once) instead of a best-effort daemon thread.
# WEBHOOK_ASYNC=1                       # 0 to force the inline/thread path
# WEBHOOK_MAX_ATTEMPTS=5                # total tries (initial + retries)
# WEBHOOK_RETRY_BACKOFF=10             # base seconds; backoff = base * 2**retry
# WEBHOOK_TIMEOUT=8                     # per-POST timeout (seconds)

# Browser scraper (optional — needs the [browser] extra: playwright).
# Enables headless rendering for JS job boards + Numbeo COL where APIs are
# paid/unavailable. Heavy; opt in explicitly. Then: `playwright install chromium`.
# BROWSER_SCRAPER_ENABLED=1

# Email delivery (optional — for password-reset emails). All five required.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
# EMAIL_FROM=no-reply@yourdomain.com
# SMTP_USE_TLS=1
# APP_BASE_URL=https://yourdomain.com   # makes reset emails contain a full link

# Rate-limiting tuning (defaults are usually fine). MAX = attempts, WINDOW = sec.
# RL_LOGIN_MAX=10
# RL_LOGIN_WINDOW=300
# RL_REGISTER_MAX=5
# RL_REGISTER_WINDOW=3600
# RL_RESET_MAX=5
# RL_RESET_WINDOW=3600
# RL_ANALYSIS_MAX=30
# RL_ANALYSIS_WINDOW=3600

# LLM cost controls (services/usage). Token usage of every real provider call
# is ledgered (table llm_usage) with an estimated USD cost. Set a per-user
# spend cap over a rolling window; 0/unset disables budgeting (count-based
# RL_ANALYSIS_* still applies).
# LLM_BUDGET_USD=0
# LLM_BUDGET_WINDOW_SECONDS=2592000     # default 30 days
# Override the estimated price table (USD per 1k tokens) wholesale:
# LLM_PRICING_JSON={"gpt-4o-mini": [0.00015, 0.0006], "claude-sonnet-4-6": [0.003, 0.015]}
# Cache identical completions (same provider/model/params/prompt) for free
# reuse — off by default; valuable for repeated/identical analyses.
# LLM_CACHE_COMPLETIONS=1

# UI / discoverability
# TELEGRAM_BOT_USERNAME=YourBot        # if set, sidebar shows a link to t.me/...
# REDIS_URL=redis://localhost:6379/1   # shared backend for rate-limit + cache +
#                                      # analysis checkpoints (REQUIRED for >1
#                                      # app instance; else each is in-process).
#                                      # CELERY_BROKER_URL is used as a fallback.
# CACHE_TTL_SECONDS=3600
# CHECKPOINT_TTL_SECONDS=3600

# Observability — expose this process's metrics for Prometheus.
# The REST API serves GET /metrics in Prometheus text format when enabled.
# Off by default (returns 404); set a token on any public deployment so the
# metrics aren't world-readable (Prometheus sends Authorization: Bearer <tok>).
# METRICS_ENABLED=1
# METRICS_TOKEN=change-me
# Stop-gap push path (cron): `python -m worker.metrics_dump --push`
# METRICS_PUSHGATEWAY_URL=http://pushgateway:9091
# METRICS_JOB=joboffer_scanner

# Marketing site / waitlist — CORS allow-origin for the public POST /waitlist
# endpoint (the landing page's origin). Defaults to '*' (dev).
# LANDING_ORIGIN=https://yourdomain.com

# Telegram bot channel (alternative to the Streamlit UI)
# TELEGRAM_BOT_TOKEN=...               # from @BotFather

# Secrets at rest — envelope-encrypt the TOTP 2FA secret (and any future
# sensitive low-volume fields). Set to any string/passphrase; a Fernet key is
# derived from it (SHA-256). When UNSET, secrets are stored plaintext (dev/demo)
# and legacy rows are re-encrypted lazily once a key is configured. In prod,
# source this from a KMS-decrypted data key at boot. Rotating the key without
# re-encrypting existing rows will break 2FA verification for those users.
# SECRETS_ENCRYPTION_KEY=change-me-to-a-long-random-string

# Billing (optional — [billing] extra: stripe). When STRIPE_SECRET_KEY is
# UNSET, billing is disabled and every user is on the "unlimited" tier —
# self-hosted deployments are never constrained. When set, users without a
# subscription are on the FREE tier (5 analyses / 2 tailored docs per rolling
# 30 days, fast model only); paid tiers come from Stripe via the webhook
# (POST /v1/billing/webhook).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...      # from the Stripe webhook endpoint config
# STRIPE_PRICE_PRO=price_...           # recurring price id for the Pro plan
# STRIPE_PRICE_POWER=price_...         # recurring price id for the Power plan
# TIER_WINDOW_DAYS=30                  # rolling window for tier counters
# Override tier limits wholesale (partial per-tier overrides merge over defaults):
# TIER_LIMITS_JSON={"free": {"analyses_per_window": 10}}

# Password reset — self-hosted convenience flag.
# Set to 1 ONLY in single-user/self-hosted deployments to display reset
# tokens directly in the UI. Leave UNSET in multi-tenant production.
# RESET_TOKEN_SURFACE_IN_UI=1
