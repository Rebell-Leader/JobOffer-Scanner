# Copy to .env and fill in whichever provider you want to use.
# Auto-detection order: Anthropic -> OpenAI -> Featherless.
# Override with LLM_PROVIDER=anthropic|openai|featherless.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=                 # optional; SDK uses default if unset

# OpenAI
# OPENAI_API_KEY=sk-...

# Featherless (OpenAI-compatible, hosts Qwen / DeepSeek)
# FEATHERLESS_API_KEY=...

# Tuning (optional)
# LLM_PROVIDER=anthropic
# LLM_TEMPERATURE=0.4
# LLM_MAX_TOKENS=2000
# LLM_MAX_RETRIES=3

# Persistence
# DATABASE_URL=postgresql://user:pass@localhost:5432/joboffer
# Default (unset): SQLite at ./data/joboffer.db (created automatically).

# Phase 1 data sources (optional, degrade honestly if unset)
# NEWS_API_KEY=...                    # newsapi.org for real company news
# LAYOFFS_DATASET_URL=...              # JSON dataset URL with layoff records

# Phase 4 — real salary benchmarks via Adzuna (free tier, ~1000 calls/month)
# Sign up at https://developer.adzuna.com/
# ADZUNA_APP_ID=...
# ADZUNA_APP_KEY=...

# Phase 5 — real cost-of-living data (JSON dataset, e.g. self-hosted Numbeo
# scrape or any city-keyed index). Each record needs a "city" field; supported
# numeric fields: cost_of_living_index, rent_index, groceries_index,
# local_purchasing_power, monthly_rent_1bedroom_city_center, etc.
# COL_DATASET_URL=...

# Migrations: set to 1 to opt into Alembic-managed schema. When unset, init_db
# uses create_all (zero-config). With USE_ALEMBIC=1 run `alembic upgrade head`
# at deploy time.
# USE_ALEMBIC=1

# Async job queue (optional — needs the [worker] extra: celery + redis).
# When unset, analysis runs in-process. docker-compose sets this automatically.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Browser scraper (optional — needs the [browser] extra: playwright).
# Enables headless rendering for JS job boards + Numbeo COL where APIs are
# paid/unavailable. Heavy; opt in explicitly. Then: `playwright install chromium`.
# BROWSER_SCRAPER_ENABLED=1

# Email delivery (optional — for password-reset emails). All five required.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
# EMAIL_FROM=no-reply@yourdomain.com
# SMTP_USE_TLS=1
# APP_BASE_URL=https://yourdomain.com   # makes reset emails contain a full link

# Rate-limiting tuning (defaults are usually fine). MAX = attempts, WINDOW = sec.
# RL_LOGIN_MAX=10
# RL_LOGIN_WINDOW=300
# RL_REGISTER_MAX=5
# RL_REGISTER_WINDOW=3600
# RL_RESET_MAX=5
# RL_RESET_WINDOW=3600
# RL_ANALYSIS_MAX=30
# RL_ANALYSIS_WINDOW=3600

# UI / discoverability
# TELEGRAM_BOT_USERNAME=YourBot        # if set, sidebar shows a link to t.me/...
# REDIS_URL=redis://localhost:6379/1   # shared backend for rate-limit + cache +
#                                      # analysis checkpoints (REQUIRED for >1
#                                      # app instance; else each is in-process).
#                                      # CELERY_BROKER_URL is used as a fallback.
# CACHE_TTL_SECONDS=3600
# CHECKPOINT_TTL_SECONDS=3600

# Telegram bot channel (alternative to the Streamlit UI)
# TELEGRAM_BOT_TOKEN=...               # from @BotFather

# Password reset — self-hosted convenience flag.
# Set to 1 ONLY in single-user/self-hosted deployments to display reset
# tokens directly in the UI. Leave UNSET in multi-tenant production.
# RESET_TOKEN_SURFACE_IN_UI=1
